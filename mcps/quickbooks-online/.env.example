# Customer deployment mode: use a unique VAS broker credential.
# Do not configure VantaSoft's Intuit client secret or a QuickBooks refresh token
# on an external customer host.
QUICKBOOKS_BROKER_URL=
QUICKBOOKS_CONNECTION_ID=
QUICKBOOKS_BROKER_TOKEN=

# Standalone mode: only for an owner-controlled backend or internal profile.
# Leave all broker variables empty when using this mode.
QUICKBOOKS_CLIENT_ID=your_client_id_here
QUICKBOOKS_CLIENT_SECRET=your_client_secret_here
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_REDIRECT_URI=http://localhost:8000/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Mutating tools are hidden by default. Only enable them in a profile that is
# authorized to change accounting data. Human approval is still required for
# money movement and other high-impact operations.
# QUICKBOOKS_ENABLE_MUTATIONS=true

# Optional restrictions after mutations are enabled
# QUICKBOOKS_DISABLE_WRITE=true    # suppress create_* and create-* tools
# QUICKBOOKS_DISABLE_UPDATE=true   # suppress update_* and update-* tools
# QUICKBOOKS_DISABLE_DELETE=true   # suppress delete_* and delete-* tools

# Optional credential file override. Hermes defaults to:
# HERMES_HOME/mcp-tokens/quickbooks-online/.env
# QUICKBOOKS_ENV_FILE=/absolute/path/to/quickbooks.env
