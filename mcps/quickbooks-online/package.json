{
    "name": "@vantasoft/quickbooks-online-mcp",
    "version": "1.0.0-vantasoft.1",
    "description": "Profile-local, read-only-by-default QuickBooks Online MCP server for Hermes",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "type": "module",
    "bin": {
        "quickbooks-online-mcp": "./dist/index.js",
        "quickbooks-online-auth": "./dist/auth-server.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc && shx chmod +x dist/*.js",
        "prepare": "npm run build",
        "watch": "tsc --watch",
        "lint:fix": "eslint . --fix",
        "lint": "eslint .",
        "auth": "node dist/auth-server.js",
        "test": "npm run build && npm run test:unit && npm run test:smoke",
        "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand",
        "test:smoke": "node --test tests/mcp-smoke.test.mjs",
        "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
        "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
        "audit:prod": "npm audit --omit=dev --audit-level=high"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "1.29.0",
        "dotenv": "16.6.1",
        "intuit-oauth": "4.2.5",
        "node-quickbooks": "2.0.50",
        "open": "9.1.0",
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "@jest/globals": "^30.3.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.13.10",
        "eslint": "^9.22.0",
        "eslint-config-prettier": "^10.1.1",
        "globals": "^16.0.0",
        "jest": "^30.2.0",
        "prettier": "3.5.3",
        "shx": "^0.3.4",
        "ts-jest": "^29.4.6",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.1"
    },
    "engines": {
        "node": ">=20"
    },
    "author": "Intuit Inc. and contributors; VantaSoft modifications",
    "repository": {
        "type": "git",
        "url": "https://github.com/VantaSoft/vantasoft-hermes-library.git",
        "directory": "mcps/quickbooks-online"
    },
    "overrides": {
        "fast-xml-parser": "5.10.1",
        "underscore": "1.13.8",
        "uuid": "11.1.1",
        "jws": "3.2.3"
    }
}
