{
  "schemaVersion": 1,
  "componentId": "quickbooks-online",
  "displayName": "QuickBooks Online MCP",
  "safeDefault": "read-only",
  "runtime": {
    "command": "node",
    "minimumVersion": "20.0.0",
    "versionArgs": ["--version"]
  },
  "install": {
    "bootstrap": [
      ["npm", "ci", "--ignore-scripts"],
      ["npm", "run", "build"],
      ["npm", "run", "test:smoke"],
      ["npm", "run", "audit:prod"],
      ["npm", "prune", "--omit=dev", "--ignore-scripts"]
    ],
    "requiredFiles": ["dist/index.js", "dist/auth-server.js"]
  },
  "transport": {
    "serverName": "quickbooks_online",
    "command": "node",
    "args": ["${INSTALL_DIR}/dist/index.js"],
    "env": {
      "QUICKBOOKS_ENABLE_MUTATIONS": "false",
      "QUICKBOOKS_ENV_FILE": "${CREDENTIAL_FILE}"
    },
    "timeout": 120,
    "connectTimeout": 30
  },
  "credentials": {
    "directory": "mcp-tokens/quickbooks-online",
    "template": ".env.example",
    "target": "mcp-tokens/quickbooks-online/.env"
  },
  "nextSteps": [
    "For a customer deployment, provision QUICKBOOKS_BROKER_URL, QUICKBOOKS_CONNECTION_ID, and QUICKBOOKS_BROKER_TOKEN through the VAS broker operator.",
    "Use standalone Intuit app credentials only on an owner-controlled backend or internal profile.",
    "Reload MCP servers or restart the target Hermes gateway, then confirm the read-only QuickBooks tools are available."
  ]
}
