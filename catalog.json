{
  "schemaVersion": 1,
  "components": [
    {
      "id": "google-workspace",
      "name": "Google Workspace MCP",
      "type": "mcp",
      "path": "mcps/google-workspace",
      "installManifest": "mcps/google-workspace/mcp-install.json",
      "profileScoped": true,
      "credentialModel": "HERMES_HOME/mcp-tokens/google-workspace",
      "supportsMultipleAccounts": true
    },
    {
      "id": "quickbooks-online",
      "name": "QuickBooks Online MCP",
      "type": "mcp",
      "path": "mcps/quickbooks-online",
      "installManifest": "mcps/quickbooks-online/mcp-install.json",
      "profileScoped": true,
      "credentialModel": "HERMES_HOME/mcp-tokens/quickbooks-online/.env",
      "safeDefault": "read-only",
      "upstream": "intuit/quickbooks-online-mcp-server"
    },
    {
      "id": "shopify-admin",
      "name": "Shopify Admin MCP",
      "type": "mcp",
      "path": "mcps/shopify-admin",
      "installManifest": "mcps/shopify-admin/mcp-install.json",
      "profileScoped": true,
      "credentialModel": "HERMES_HOME/mcp-tokens/shopify-admin/credentials.json",
      "supportsMultipleAccounts": true,
      "safeDefault": "read-only",
      "upstreamClient": "@shopify/admin-api-client@1.1.2"
    },
    {
      "id": "telvana-admin",
      "name": "Telvana Admin MCP",
      "type": "mcp",
      "path": "mcps/telvana-admin",
      "installManifest": "mcps/telvana-admin/mcp-install.json",
      "profileScoped": true,
      "credentialModel": "HERMES_HOME/mcp-tokens/telvana-admin/credentials.json",
      "safeDefault": "read-only",
      "supportsEnvironments": ["development", "staging", "production"]
    },
    {
      "id": "agent-messaging",
      "name": "Agent Messaging",
      "type": "hermes-plugin",
      "path": "plugins/agent-messaging",
      "profileScoped": true,
      "providesTools": [
        "list_agents",
        "agent_status",
        "message_agent",
        "agent_reply"
      ]
    },
    {
      "id": "install-vantasoft-mcp",
      "name": "Install VantaSoft MCP",
      "type": "hermes-skill",
      "path": "skills/install-vantasoft-mcp",
      "profileScoped": true,
      "runtimePlugin": false,
      "installsComponentType": "mcp"
    },
    {
      "id": "create-agent-profile",
      "name": "Create Agent Profile",
      "type": "hermes-skill",
      "path": "skills/create-agent-profile",
      "profileScoped": true,
      "runtimePlugin": false,
      "companionComponents": [
        "agent-messaging",
        "slack-app-manifest"
      ]
    },
    {
      "id": "slack-app-manifest",
      "name": "Slack App Manifest",
      "type": "hermes-skill",
      "path": "skills/slack-app-manifest",
      "profileScoped": true,
      "runtimePlugin": false
    },
    {
      "id": "approval-gated-email",
      "name": "Approval-Gated Email",
      "type": "hermes-skill",
      "path": "skills/approval-gated-email",
      "profileScoped": true,
      "runtimePlugin": false,
      "companionComponent": "google-workspace"
    },
    {
      "id": "approval-gated-calendar",
      "name": "Approval-Gated Calendar",
      "type": "hermes-skill",
      "path": "skills/approval-gated-calendar",
      "profileScoped": true,
      "runtimePlugin": false,
      "companionComponent": "google-workspace"
    }
  ]
}
